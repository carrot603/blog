    <item>
      <title></title>
      <link>http://localhost:1313/posts/carrot/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/posts/carrot/</guid>
      <description>&lt;!DOCTYPE html&gt;
&lt;html lang=&#34;zh-Hant&#34;&gt;
&lt;head&gt;
&lt;meta charset=&#34;UTF-8&#34; /&gt;
&lt;meta name=&#34;viewport&#34; content=&#34;width=device-width, initial-scale=1.0&#34;/&gt;
&lt;title&gt;3D Carrot World&lt;/title&gt;
&lt;style&gt;

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  width:100%;
  height:100vh;
  overflow:hidden;

  display:flex;
  justify-content:center;
  align-items:center;

  font-family:sans-serif;

  background:
    linear-gradient(
      to bottom,
      #7fd8ff 0%,
      #dff7ff 55%,
      #8fdd73 55%,
      #5cb84f 100%
    );

  perspective:1200px;
}

/* 雲 */

.cloud{
  position:absolute;
  background:white;
  border-radius:999px;
  opacity:0.9;

  animation:cloudMove linear infinite;
}

.cloud::before,
.cloud::after{
  content:&#34;&#34;;
  position:absolute;
  background:white;
  border-radius:50%;
}

.cloud1{
  width:180px;
  height:60px;

  top:10%;
  left:-220px;

  animation-duration:28s;
}

.cloud1::before{
  width:70px;
  height:70px;

  top:-30px;
  left:25px;
}

.cloud1::after{
  width:90px;
  height:90px;

  top:-40px;
  right:20px;
}

.cloud2{
  width:140px;
  height:50px;

  top:25%;
  left:-180px;

  animation-duration:40s;
}

.cloud2::before{
  width:55px;
  height:55px;

  top:-20px;
  left:18px;
}

.cloud2::after{
  width:70px;
  height:70px;

  top:-28px;
  right:15px;
}

@keyframes cloudMove{
  from{
    transform:translateX(0);
  }

  to{
    transform:translateX(140vw);
  }
}

/* 草地 */

.ground{
  position:absolute;
  bottom:0;

  width:100%;
  height:38%;

  background:
    linear-gradient(
      to top,
      #4b983f,
      #79d36d
    );
}

/* 主場景 */

.scene{
  position:relative;

  display:flex;
  flex-direction:column;
  align-items:center;
}

/* 漂浮 */

.float{
  animation:float 3s ease-in-out infinite;
}

/* 3D旋轉 */

.spin{
  transform-style:preserve-3d;
  animation:spin 7s linear infinite;
}

/* 胡蘿蔔 */

.carrot{
  font-size:180px;

  filter:
    drop-shadow(
      0 25px 18px rgba(0,0,0,0.22)
    );
}

h1{
  margin-top:24px;

  font-size:42px;
  color:#d96b1f;

  text-shadow:
    0 4px 10px rgba(255,255,255,0.7);
}

p{
  margin-top:8px;

  font-size:20px;
  color:#47663f;
}

/* 動畫 */

@keyframes float{

  0%{
    transform:
      translateY(0px);
  }

  50%{
    transform:
      translateY(-35px);
  }

  100%{
    transform:
      translateY(0px);
  }
}

@keyframes spin{

  from{
    transform:
      rotateY(0deg);
  }

  to{
    transform:
      rotateY(360deg);
  }
}

&lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
&lt;!-- 雲 --&gt;
&lt;div class=&#34;cloud cloud1&#34;&gt;&lt;/div&gt;
&lt;div class=&#34;cloud cloud2&#34;&gt;&lt;/div&gt;
&lt;!-- 主體 --&gt;
&lt;div class=&#34;scene&#34;&gt;
  &lt;div class=&#34;float&#34;&gt;
&lt;pre&gt;&lt;code&gt;&amp;lt;div class=&amp;quot;spin&amp;quot;&amp;gt;

  &amp;lt;div class=&amp;quot;carrot&amp;quot;&amp;gt;
    🥕
  &amp;lt;/div&amp;gt;

&amp;lt;/div&amp;gt;
&lt;/code&gt;&lt;/pre&gt;
  &lt;/div&gt;
  &lt;h1&gt;3D CARROT&lt;/h1&gt;
  &lt;p&gt;
    floating in the sky...
  &lt;/p&gt;</description>
