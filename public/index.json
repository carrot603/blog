eY(90deg) rotateZ(-10deg) translateZ(2px); }\n.leaf-i3 { transform: rotateY(180deg) rotateZ(20deg) translateZ(-2px); }\n.leaf-i4 { transform: rotateY(270deg) rotateZ(-15deg) translateZ(-2px); }\n\n.title-3d {\n  margin-top: 20px;\n  font-size: 28px;\n  color: #d96b1f;\n  text-shadow: 0 2px 5px rgba(255,255,255,0.8);\n  font-weight: bold;\n}\n\n@keyframes floatInner {\n  0%, 100% { transform: translateY(0px); }\n  50% { transform: translateY(-20px); }\n}\n\n@keyframes spinInner {\n  from { transform: rotateX(-15deg) rotateY(0deg); }\n  to { transform: rotateX(-15deg) rotateY(360deg); }\n}\n\u003c/style\u003e\n\u003cdiv class=\"carrot-container\"\u003e\n  \u003cdiv class=\"cloud-inner cloud-i1\"\u003e\u003c/div\u003e\n  \u003cdiv class=\"scene-inner\"\u003e\n    \u003cdiv class=\"float-inner\"\u003e\n      \u003cdiv class=\"stage3d-inner\"\u003e\n        \u003cdiv class=\"spin-inner\"\u003e\n          \u003cdiv class=\"carrot-3d-inner\"\u003e\n            \u003cdiv class=\"leaf-inner leaf-i1\"\u003e\u003c/div\u003e\n            \u003cdiv class=\"leaf-inner leaf-i2\"\u003e\u003c/div\u003e\n            \u003cdiv class=\"leaf-inner leaf-i3\"\u003e\u003c/div\u003e\n            \u003cdiv class=\"leaf-inner leaf-i4\"\u003e\u003c/div\u003e\n            \u003cdiv class=\"cone-top-inner\"\u003e\u003c/div\u003e\n            \u003cdiv class=\"cone-side-inner side-f\"\u003e\u003c/div\u003e\n            \u003cdiv class=\"cone-side-inner side-b\"\u003e\u003c/div\u003e\n            \u003cdiv class=\"cone-side-inner side-l\"\u003e\u003c/div\u003e\n            \u003cdiv class=\"cone-side-inner side-r\"\u003e\u003c/div\u003e\n          \u003c/div\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n    \u003c/div\u003e\n    \u003cdiv class=\"title-3d\"\u003eREAL 3D CARROT\u003c/div\u003e\n  \u003c/div\u003e\n\u003c/div\u003e","title":"3D🥕"},{"content":"你好我叫江俊佑，很高興認識你。歡迎來到我的 blog，這是我給自己的十九歲生日禮物，也是我的秘密基地。\n","permalink":"http://localhost:1313/posts/hello/","summary":"\u003cp\u003e你好我叫江俊佑，很高興認識你。歡迎來到我的 blog，這是我給自己的十九歲生日禮物，也是我的秘密基地。\u003c/p\u003e","title":"你好"},{"content":"我希望每天都能四點半起來，喝杯水拉拉筋，親手磨一杯咖啡，看著日出吃早餐。看點書之後出門運動，不論是跑步、騎車，或是散散步也好，總之要好好享受靜謐的早晨。 回家洗完澡，打開手機看看 Wiwi 更新了沒有，讀 Taipei Times，然後繼續看書。 練琴不先從哈農跟音階開始，反而是巴哈最有助於醒腦，之後有練習曲需要攻克。必須練的東西在中午前就要全部解決。 來頓豐盛的午餐，然後繼續看書。小睡二十分鐘，然後繼續看書。下午練琴就是機械式的練習或找音，當然最重要的還是練自己想練的曲子。 六點吃晚餐，不能太飽，這樣才能早點睡覺。然後繼續看書。洗澡，跟家人聊聊天，然後繼續看書。八點結束一天，想想明天要做什麼，最後伸展、上床。八點半就寢，睡滿七個半小時。美好的一天是從前一晚開始規劃，用好的睡眠開啟。\n以上寫於 2026-05-15 15 : 19\n","permalink":"http://localhost:1313/posts/ideal-daily/","summary":"\u003cp\u003e我希望每天都能\u003ca href=\"https://findbook.com.tw/9789861756769\"\u003e四點半\u003c/a\u003e起來，喝杯水拉拉筋，親手磨一杯\u003ca href=\"\"\u003e咖啡\u003c/a\u003e，看著日出吃早餐。看點書之後出門運動，不論是跑步、\u003ca href=\"\"\u003e騎車\u003c/a\u003e，或是散散步也好，總之要好好享受靜謐的\u003ca href=\"\"\u003e早晨\u003c/a\u003e。\n回家洗完澡，打開手機看看 \u003ca href=\"https://wiwi.blog\"\u003eWiwi\u003c/a\u003e 更新了沒有，讀 \u003ca href=\"https://taipeitimes.com\"\u003eTaipei Times\u003c/a\u003e，然後繼續看書。\n練琴不先從哈農跟音階開始，反而是巴哈最有助於醒腦，之後有練習曲需要攻克。必須練的東西在中午前就要全部解決。\n來頓豐盛的午餐，然後繼續看書。\u003ca href=\"\"\u003e小睡\u003c/a\u003e二十分鐘，然後繼續看書。下午練琴就是機械式的練習或找音，當然最重要的還是練自己想練的曲子。\n六點吃晚餐，不能太飽，這樣才能早點睡覺。然後繼續看書。洗澡，跟家人聊聊天，然後繼續看書。八點結束一天，想想明天要做什麼，最後伸展、上床。八點半就寢，睡滿七個半小時。美好的一天是從前一晚開始規劃，用好的睡眠開啟。\u003c/p\u003e","title":"理想的日常"},{"content":" REAL 3D CARROT ","permalink":"http://localhost:1313/posts/carrot3d/","summary":"\u003cstyle\u003e\n.carrot-container {\n  width: 100%;\n  height: 500px; /* 給予它一個固定的展示舞台高度 */\n  position: relative;\n  overflow: hidden;\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  background: linear-gradient(\n    to bottom,\n    #7fd8ff 0%,\n    #dff7ff 55%,\n    #8fdd73 55%,\n    #5cb84f 100%\n  );\n  perspective: 1600px;\n  border-radius: 12px; /* 讓它像一個精緻的展示外框 */\n  box-shadow: 0 10px 30px rgba(0,0,0,0.1);\n  margin: 20px 0;\n}\n\n.cloud-inner {\n  position: absolute;\n  background: white;\n  border-radius: 999px;\n  opacity: 0.8;\n  animation: cloudMoveInner linear infinite;\n}\n.cloud-inner::before, .